<html>
<head>
<title>Success</title>
<link rel="stylesheet" href="css/style.css">

<style>
.success-box {
    width: 350px;
    margin: 120px auto;
    padding: 30px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.2);
    text-align: center;
}

.success-box h2 {
    color: green;
    margin-bottom: 20px;
}

.success-box a {
    display: inline-block;
    text-decoration: none;
    background: #4facfe;
    color: white;
    padding: 10px 20px;
    border-radius: 8px;
    transition: 0.3s;
    font-weight: bold;
}

.success-box a:hover {
    background: #007bff;
}
</style>

</head>

<body>

<div class="success-box">
    <h2>Feedback Submitted Successfully</h2>
    <a href="index.jsp">Go Back</a>
</div>

</body>
</html>